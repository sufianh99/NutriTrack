classDiagram
    direction TB

    %% ── Database Models ──────────────────────────────────
    class User {
        +int id
        +str username
        +str password_hash
    }

    class UserProfile {
        +int id
        +int user_id
        +int age
        +float height_cm
        +float weight_kg
        +str gender
        +str activity_level
        +str goal
    }

    class DailyGoal {
        +int id
        +int user_id
        +date date
        +float calorie_goal
        +float protein_goal
        +float fat_goal
        +float carb_goal
    }

    class FoodEntry {
        +int id
        +int user_id
        +date date
        +str name
        +float amount_g
        +float calories_per_100g
        +float protein_per_100g
        +float fat_per_100g
        +float carbs_per_100g
    }

    %% ── Logic Modules (pure functions) ───────────────────
    class calculator {
        <<module>>
        +calculate_bmr(weight_kg, height_cm, age, gender) float
        +calculate_tdee(bmr, activity_level) float
        +apply_goal_modifier(tdee, goal) float
        +calculate_macros(calorie_goal) dict
    }

    class nutrition {
        <<module>>
        +scale_nutrients(amount_g, cal, prot, fat, carbs) dict
        +sum_daily_nutrients(entries) dict
        +progress_status(actual, goal) str
    }

    class api_client {
        <<module>>
        +search_food(query, max_results) list
        -_fetch_products(query, max_results) list
        -_extract_name(product) str
    }

    class APIError {
        <<exception>>
    }

    %% ── Forms (Flask-WTF) ────────────────────────────────
    class LoginForm {
        +StringField username
        +PasswordField password
        +SubmitField submit
    }

    class RegisterForm {
        +StringField username
        +PasswordField password
        +PasswordField confirm_password
        +SubmitField submit
    }

    class OnboardingForm {
        +IntegerField age
        +FloatField height_cm
        +FloatField weight_kg
        +SelectField gender
        +SelectField activity_level
        +SelectField goal
        +SubmitField submit
    }

    class FoodEntryForm {
        +StringField name
        +FloatField amount_g
        +FloatField calories_per_100g
        +FloatField protein_per_100g
        +FloatField fat_per_100g
        +FloatField carbs_per_100g
        +SubmitField submit
    }

    class DeleteForm {
        <<CSRF only>>
    }

    %% ── Relationships ────────────────────────────────────
    User "1" --> "0..1" UserProfile : has profile
    User "1" --> "*" DailyGoal : has goals
    User "1" --> "*" FoodEntry : tracks food

    UserProfile --> calculator : provides input for BMR/TDEE
    calculator --> DailyGoal : produces calorie and macro goals

    FoodEntry --> nutrition : entries scaled and summed
    DailyGoal --> nutrition : goal values for progress comparison

    api_client --> FoodEntry : populates nutrition data
    api_client ..> APIError : throws

    LoginForm ..> User : authenticates
    RegisterForm ..> User : creates
    OnboardingForm ..> UserProfile : creates/updates
    FoodEntryForm ..> FoodEntry : creates
